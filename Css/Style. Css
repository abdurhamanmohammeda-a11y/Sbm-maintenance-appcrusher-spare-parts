:root{
--primary:#FFA500;
--bg:#0f1117;
--card:#1c1f26;
--text:#e6edf3;
--accent:#39FF14;
}

body{
margin:0;
background:var(--bg);
color:var(--text);
font-family:'Roboto',sans-serif;
}

header{
text-align:center;
padding:25px;
background:linear-gradient(180deg,#FFA500,#111);
}

.container{
max-width:700px;
margin:auto;
padding:15px;
}

.card{
background:var(--card);
padding:20px;
border-radius:15px;
margin-bottom:20px;
}
